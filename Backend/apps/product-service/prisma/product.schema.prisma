datasource db {
    provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

model Product {
    id          Int     @id @default(autoincrement())
    name        String  @unique
    description String
    price       Float
    category    String?
    stock       Int     @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

